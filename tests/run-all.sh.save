#!/usr/bin/env bash
set -euo pipefail

# Run all BATS test suites in parallel.
# Each .bats file runs its own tests sequentially, but all suites run concurrently.
# Each individual test gets a random Docker Compose project name + subnet.
#
# Usage:
#   ./run-all.sh              # Run all suites (4 parallel jobs per suite)
#   ./run-all.sh --build      # Build images first, then run
#   ./run-all.sh --suite negotiate  # Run only one suite
#
# Prerequisites: bats (https://github.com/bats-core/bats-core)

cd "$(dirname "$0")"

BUILD=false
SUITE=""
JOBS=10

while [[ $# -gt 0 ]]; do
    case "$1" in
        --build)   BUILD=true; shift ;;
        --suite)   SUITE="$2"; shift 2 ;;
        --jobs|-j) JOBS="$2"; shift 2 ;;
        *)         echo "Unknown arg: $1"; exit 1 ;;
    esac
done

# Check for bats
if ! command -v bats &>/dev/null; then
    echo "Error: bats not found. Install via: brew install bats-core"
    exit 1
fi

# Build images if requested
if [[ "$BUILD" == "true" ]]; then
    echo "=== Building Docker images ==="
    docker compose build
    echo ""
fi

# Collect test files
if [[ -n "$SUITE" ]]; then
    FILES=("${SUITE}-tests.bats")
    if [[ ! -f "${FILES[0]}" ]]; then
        FILES=("${SUITE}.bats")
    fi
else
    FILES=(negotiate-tests.bats force-mode-tests.bats health-report-tests.bats three-node-tests.bats)
fi

# Verify files exist
for f in "${FILES[@]}"; do
    if [[ ! -f "$f" ]]; then
        echo "Error: test file not found: $f"
        exit 1
    fi
done

echo "=== Running ${#FILES[@]} test suite(s) with --jobs $JOBS ==="
echo "Suites: ${FILES[*]}"
echo ""

# Run all suites via bats --jobs for maximum parallelism
# Each test within each suite gets its own random project/subnet
bats --jobs "$JOBS" --timing "${FILES[@]}"

echo ""
echo "=== All tests passed ==="
